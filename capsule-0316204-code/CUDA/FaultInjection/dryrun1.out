ptxas -arch=sm_35 -m64  "2mm.ptx"  -o "2mm.sm_35.cubin" 
fatbinary --create="2mm.fatbin" -64 --cicc-cmdline="-ftz=0 -prec_div=1 -prec_sqrt=1 -fmad=1 " "--image3=kind=elf,sm=35,file=2mm.sm_35.cubin" "--image3=kind=ptx,sm=35,file=2mm.ptx" --embedded-fatbin="2mm.fatbin.c" 

cudafe++ --c++14 --gnu_version=90500 --orig_src_file_name "2mm.cu" --allow_managed  --m64 --parse_templates --gen_c_file_name "2mm.cudafe1.cpp" --stub_file_name "2mm.cudafe1.stub.c" --module_id_file_name "2mm.module_id" "2mm.cpp4.ii" 
